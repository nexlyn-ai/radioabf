---
import Base from "../../layouts/Base.astro";
export const prerender = false;
---

<Base
  title="Airplay Insights — RadioABF"
  description="Automatic airplay analytics from RadioABF rotation."
  canonical="/music/insights"
  image="/og-image.jpg"
>
  <div id="insightsPageRoot">
    <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#0A1F33] p-5 sm:p-6 mb-6 shadow-2xl">
      <div class="pointer-events-none absolute -top-40 -left-40 w-[520px] h-[520px] rounded-full bg-cyan-500/15 blur-[120px]"></div>
      <div class="pointer-events-none absolute -bottom-40 -right-40 w-[520px] h-[520px] rounded-full bg-blue-600/15 blur-[120px]"></div>

      <div class="relative z-10">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="min-w-0">
            <div class="flex items-center gap-3 text-sm tracking-widest text-white/60 uppercase mb-3">
              <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
              Music Portal
            </div>
            <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight">
              Airplay <span class="text-cyan-200">Insights</span>
            </h1>
            <p class="text-white/65 mt-3 max-w-2xl">
              Now playing, automatic rotation analytics and realtime airplay intelligence by RadioABF.
            </p>
          </div>

          <div class="flex flex-col items-start lg:items-end gap-3">
            <div class="flex items-center gap-2 flex-nowrap overflow-x-auto no-scrollbar">
              <a
                href="/music"
                class="text-xs text-white/70 border border-white/10 bg-white/5 px-4 py-2 rounded-xl hover:bg-white/10 transition flex-none"
              >
                Music Portal
              </a>
              <a
                href="/music/insights"
                class="text-xs text-black font-semibold border border-cyan-300/30 bg-cyan-300 px-4 py-2 rounded-xl flex-none"
              >
                Airplay Insights
              </a>
            </div>

            <div class="flex items-center justify-start lg:justify-end gap-2 flex-nowrap overflow-x-auto no-scrollbar">
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Auto charts
              </span>
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Based on live history
              </span>
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Updates every 8s
              </span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="mt-6 grid grid-cols-1 xl:grid-cols-[minmax(0,1fr)_minmax(0,0.85fr)] gap-6 items-start">
      <div class="space-y-6">
        <div class="rounded-3xl border border-white/10 bg-[#0A1F33] overflow-hidden shadow-xl">
          <div class="p-5 md:p-6 border-b border-white/10">
            <div class="flex items-center justify-between gap-4 flex-wrap">
              <div class="min-w-0">
                <div class="text-sm text-white/60 uppercase tracking-wider">Now playing</div>
                <div class="text-xs text-white/50 mt-1">Live metadata • clean titles • realtime rotation source</div>
              </div>
              <div class="flex items-center gap-2">
                <div
                  id="npLiveBadge"
                  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-500/15 border border-red-500/25 text-red-200 text-xs font-semibold tracking-wider"
                >
                  <span class="w-2 h-2 rounded-full bg-red-400 animate-pulse"></span>
                  LIVE
                </div>
                <div
                  id="npCoverSource"
                  class="hidden inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold border tabular-nums"
                  aria-label="Cover source"
                >
                  —
                </div>
                <div
                  id="npTimeBadge"
                  class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-cyan-500/10 border border-cyan-400/20 text-cyan-200 text-xs font-semibold tabular-nums"
                  aria-label="Now playing time"
                >
                  <span class="w-2 h-2 rounded-full bg-cyan-300/80"></span>
                  <span id="musicTime">--:--</span>
                </div>
              </div>
            </div>

            <div class="mt-5 rounded-3xl border border-white/10 bg-white/5 overflow-hidden">
              <div class="p-4 md:p-5 flex flex-col sm:flex-row gap-5 items-center sm:items-stretch">
                <div class="flex-none">
                  <div
                    id="musicCoverWrapper"
                    class="abfCover w-24 h-24 md:w-28 md:h-28 rounded-2xl border border-white/10 overflow-hidden shadow-xl bg-black/20"
                  >
                    <img id="musicCover" class="hidden w-full h-full object-cover" alt="Current cover" />
                    <div class="abfCoverFallback w-full h-full grid place-items-center">
                      <img src="/logo-abf.png" alt="ABF" loading="lazy" decoding="async" class="w-16 h-16 opacity-90" />
                    </div>
                  </div>
                </div>

                <div class="min-w-0 flex-1">
                  <div id="musicArtist" class="text-xl md:text-2xl font-extrabold text-white truncate leading-tight">—</div>
                  <div class="mt-1 flex items-center gap-2 min-w-0">
                    <div id="musicTitle" class="text-white/70 text-base md:text-lg truncate min-w-0 flex-1">—</div>
                    <span
                      id="npNewBadge"
                      class="hidden items-center justify-center px-2.5 py-1 rounded-full text-[11px] font-extrabold border bg-rose-500/15 border-rose-400/30 text-rose-100 tracking-wide flex-none"
                    >
                      NEW
                    </span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <div class="p-4 md:p-6">
            <div class="flex items-center justify-between gap-4 mb-4">
              <div class="text-sm text-white/60 uppercase tracking-wider">Insight snapshot</div>
              <div class="text-xs text-white/50">Built from recent airplay history</div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-3">
              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                <div class="text-xs text-white/50 uppercase tracking-wide">Most played today</div>
                <div id="quickTodayTrack" class="mt-2 font-extrabold text-white truncate">—</div>
                <div id="quickTodayCount" class="text-white/60 text-sm mt-1">—</div>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                <div class="text-xs text-white/50 uppercase tracking-wide">Trending now</div>
                <div id="quickTrendTrack" class="mt-2 font-extrabold text-white truncate">—</div>
                <div id="quickTrendCount" class="text-white/60 text-sm mt-1">—</div>
              </div>

              <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4">
                <div class="text-xs text-white/50 uppercase tracking-wide">Fresh entry</div>
                <div id="quickNewTrack" class="mt-2 font-extrabold text-white truncate">—</div>
                <div id="quickNewCount" class="text-white/60 text-sm mt-1">—</div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <aside class="space-y-6">
        <div class="rounded-3xl border border-white/10 bg-[#0A1F33] overflow-hidden shadow-xl">
          <div class="p-5 border-b border-white/10 flex items-start justify-between gap-4">
            <div class="min-w-0">
              <div class="text-sm text-white/60 uppercase tracking-wider">How it works</div>
              <div class="text-xs text-white/50 mt-1">Automatic charts • realtime updates</div>
            </div>
            <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-1.5 rounded-xl flex-none">
              Live
            </div>
          </div>

          <div class="p-4 md:p-5">
            <ul class="text-sm text-white/70 leading-relaxed space-y-3 list-disc pl-5">
              <li><strong>Most played</strong><br />Tracks with the strongest recent rotation.</li>
              <li><strong>Trending now</strong><br />Momentum over the last 24h versus previous 24h.</li>
              <li><strong>Most played today</strong><br />Today’s highest spin count.</li>
              <li><strong>New entries</strong><br />Tracks still inside their 7-day fresh window.</li>
            </ul>

            <p class="mt-4 text-sm text-white/80 italic">
              “Airplay Insights gives a live view of the RadioABF rotation — automatic, transparent and dynamic.”
            </p>
          </div>
        </div>
      </aside>
    </section>

    <section class="mt-6">
      <div class="rounded-3xl border border-white/10 bg-[#0A1F33] overflow-hidden shadow-2xl relative">
        <div class="pointer-events-none absolute -top-28 -left-28 w-[320px] h-[320px] rounded-full bg-cyan-500/10 blur-[110px]"></div>
        <div class="pointer-events-none absolute -bottom-28 -right-28 w-[320px] h-[320px] rounded-full bg-blue-600/10 blur-[110px]"></div>

        <div class="relative z-10 p-5 sm:p-6 border-b border-white/10">
          <div class="flex items-start justify-between gap-4 flex-wrap">
            <div class="min-w-0">
              <div class="flex items-center gap-3 text-sm tracking-widest text-white/60 uppercase mb-3">
                <span class="w-2 h-2 bg-cyan-400 rounded-full animate-pulse"></span>
                Auto airplay insights
              </div>
              <h2 class="text-2xl sm:text-3xl font-extrabold leading-tight">
                Radio rotation <span class="text-cyan-200">in real time</span>
              </h2>
              <p class="text-white/65 mt-3 max-w-3xl">
                Automatic charts built from recent airplay history: most played tracks, current momentum, today’s rotation and fresh new entries.
              </p>
            </div>

            <div class="flex items-center justify-start lg:justify-end gap-2 flex-nowrap overflow-x-auto no-scrollbar">
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Auto charts
              </span>
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Based on live history
              </span>
              <span class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-2 rounded-xl flex-none">
                Updates every 8s
              </span>
            </div>
          </div>
        </div>

        <div class="relative z-10 p-5 sm:p-6">
          <div class="grid grid-cols-1 xl:grid-cols-12 gap-6 items-start">
            <div class="xl:col-span-7 rounded-3xl border border-white/10 bg-white/[0.03] overflow-hidden shadow-xl">
              <div class="p-5 border-b border-white/10 flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="text-sm text-white/60 uppercase tracking-wider">Most played on RadioABF</div>
                  <div class="text-xs text-white/50 mt-1">Top rotation from recent airplay history</div>
                </div>
                <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-1.5 rounded-xl flex-none">
                  Top 10
                </div>
              </div>
              <div class="p-4 md:p-5">
                <ol id="autoMostPlayed" class="space-y-3"></ol>
                <div id="autoMostPlayedEmpty" class="text-white/55 text-sm hidden">
                  Not enough recent play data yet.
                </div>
              </div>
            </div>

            <div class="xl:col-span-5 rounded-3xl border border-white/10 bg-gradient-to-br from-[#061220] via-[#0A1F33] to-[#081523] overflow-hidden shadow-xl relative">
              <div class="pointer-events-none absolute -top-24 -right-24 w-[240px] h-[240px] bg-emerald-500/10 rounded-full blur-[90px]"></div>
              <div class="p-5 border-b border-white/10 relative">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <div class="text-sm text-white/60 uppercase tracking-wider">Trending now</div>
                    <div class="text-xs text-white/50 mt-1">Tracks gaining momentum over the last 24h</div>
                  </div>
                  <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-1.5 rounded-xl flex-none">
                    Top 10
                  </div>
                </div>
              </div>
              <div class="p-4 md:p-5 relative">
                <div id="autoTrending" class="space-y-3"></div>
                <div id="autoTrendingEmpty" class="text-white/55 text-sm hidden">
                  No trend detected yet.
                </div>
              </div>
            </div>

            <div class="xl:col-span-4 rounded-3xl border border-white/10 bg-white/[0.03] overflow-hidden shadow-xl">
              <div class="p-5 border-b border-white/10 flex items-start justify-between gap-4">
                <div class="min-w-0">
                  <div class="text-sm text-white/60 uppercase tracking-wider">Most played today</div>
                  <div class="text-xs text-white/50 mt-1">Today’s strongest rotations</div>
                </div>
                <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-1.5 rounded-xl flex-none">
                  Top 10
                </div>
              </div>
              <div class="p-4 md:p-5">
                <div id="autoToday" class="space-y-3"></div>
                <div id="autoTodayEmpty" class="text-white/55 text-sm hidden">
                  No airplay recorded today yet.
                </div>
              </div>
            </div>

            <div class="xl:col-span-8 rounded-3xl border border-white/10 bg-gradient-to-br from-[#07111E] via-[#0A1F33] to-[#050B14] overflow-hidden shadow-xl relative">
              <div class="pointer-events-none absolute -bottom-24 -left-24 w-[260px] h-[260px] bg-rose-500/10 rounded-full blur-[95px]"></div>
              <div class="p-5 border-b border-white/10 relative">
                <div class="flex items-start justify-between gap-4">
                  <div class="min-w-0">
                    <div class="text-sm text-white/60 uppercase tracking-wider">New entries</div>
                    <div class="text-xs text-white/50 mt-1">Fresh tracks recently detected in the rotation</div>
                  </div>
                  <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-3 py-1.5 rounded-xl flex-none">
                    Top 12
                  </div>
                </div>
              </div>
              <div class="p-4 md:p-5 relative">
                <div id="autoNewEntries" class="grid grid-cols-1 md:grid-cols-2 gap-3"></div>
                <div id="autoNewEntriesEmpty" class="text-white/55 text-sm hidden">
                  No fresh entries detected yet.
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <style>
      .tabular-nums { font-variant-numeric: tabular-nums; }
      .no-scrollbar::-webkit-scrollbar { display:none; }
      .no-scrollbar { -ms-overflow-style:none; scrollbar-width:none; }

      #npCoverSource.directus {
        background: rgba(168,85,247,0.12);
        border-color: rgba(168,85,247,0.3);
        color: rgba(216,180,254,0.95);
      }
      #npCoverSource.itunes {
        background: rgba(236,72,153,0.12);
        border-color: rgba(236,72,153,0.3);
        color: rgba(249,168,212,0.95);
      }
      #npCoverSource.other,
      #npCoverSource.none {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.15);
        color: rgba(255,255,255,0.8);
      }
    </style>

    <script is:inline data-astro-rerun>
(() => {
  const ROUTE = "/music/insights";
  const KEY = "__abfMusicInsights";
  const DAY = 24 * 60 * 60 * 1000;

  const state = (window[KEY] = window[KEY] || {
    bound: false,
    timer: null,
    inFlight: false,
    lastRenderAt: 0,
    coverMemory: {},
    lastAutoHash: "",
  });

  function isInsightsRoute() { return window.location.pathname === ROUTE; }
  function getRoot() { return document.getElementById("insightsPageRoot"); }
  function nowTs() { return Date.now(); }

  function esc(s){
    return String(s || "")
      .replace(/&/g,"&amp;")
      .replace(/</g,"&lt;")
      .replace(/>/g,"&gt;")
      .replace(/"/g,"&quot;")
      .replace(/'/g,"&#039;");
  }

  function fmtTime(ts){
    if (!ts) return "--:--";
    const d = new Date(ts);
    const hh = String(d.getHours()).padStart(2,"0");
    const mm = String(d.getMinutes()).padStart(2,"0");
    return `${hh}:${mm}`;
  }

  function fmtDateTimeShort(ts){
    if (!ts) return "—";
    const d = new Date(ts);
    const yyyy = d.getFullYear();
    const mm = String(d.getMonth() + 1).padStart(2, "0");
    const dd = String(d.getDate()).padStart(2, "0");
    const hh = String(d.getHours()).padStart(2, "0");
    const mi = String(d.getMinutes()).padStart(2, "0");
    return `${yyyy}-${mm}-${dd} • ${hh}:${mi}`;
  }

  function fmtRelativeSince(ts){
    if (!ts) return "Recently added";
    const diff = Math.max(0, nowTs() - Number(ts));
    const mins = Math.floor(diff / 60000);
    const hours = Math.floor(diff / 3600000);
    const days = Math.floor(diff / 86400000);

    if (mins < 60) return mins <= 1 ? "Added 1 min ago" : `Added ${mins} min ago`;
    if (hours < 24) return hours === 1 ? "Added 1 hour ago" : `Added ${hours} hours ago`;
    if (days === 0) return "Added today";
    if (days === 1) return "Added yesterday";
    return `Added ${days} days ago`;
  }

  function startOfLocalDay(ts = nowTs()){
    const d = new Date(ts);
    d.setHours(0, 0, 0, 0);
    return d.getTime();
  }

  function splitTrack(entry){
    const s = String(entry || "").trim().replace(/^undefined\s*-\s*/i, "");
    const idx = s.indexOf(" - ");
    if (idx === -1) {
      const artistOnly = s.trim();
      return {
        artist: /^undefined$/i.test(artistOnly) ? "" : artistOnly,
        title: ""
      };
    }
    return {
      artist: /^undefined$/i.test(s.slice(0, idx).trim()) ? "" : s.slice(0, idx).trim(),
      title: /^undefined$/i.test(s.slice(idx + 3).trim()) ? "" : s.slice(idx + 3).trim(),
    };
  }

  function normKey(artist, title){
    return (String(artist || "") + " - " + String(title || ""))
      .toLowerCase()
      .replace(/\u00A0/g, " ")
      .replace(/\s+/g, " ")
      .replace(/[“”"']/g, "")
      .trim();
  }

  function upperArtist(s){ return String(s || "—").trim().toUpperCase(); }

  function stripTitleSuffixes(input){
    let s = String(input || "").trim();
    if (!s) return "";
    const rx = /\s*[\(\[]\s*(?:(?:extended|original|radio|club|album|single|clean|explicit|short|long)\s*)?(?:mix|edit|version|remix|re\-mix|rework|bootleg|instrumental|acapella|a\s*cappella|dub|vip|remaster(?:ed)?|mono|stereo)\b[^)\]]*[\)\]]\s*/gi;
    s = s.replace(rx, " ");
    return s.replace(/\s{2,}/g, " ").trim();
  }

  function titleCaseEN(input){
    const s = String(input || "").trim();
    if (!s) return "—";
    const lowerWords = new Set([
      "a","an","the","and","but","or","nor","for","so","yet",
      "as","at","by","for","from","in","into","near","of","on","onto","over","per","to","up","via","with","within","without"
    ]);
    const parts = s.split(/(\s+)/);
    return parts.map((chunk, idx) => {
      if (/^\s+$/.test(chunk)) return chunk;
      const word = chunk;
      if (word === word.toUpperCase() && /[A-Z]/.test(word) && word.length <= 6) return word;
      const hyParts = word.split("-");
      const rebuilt = hyParts.map((w, hIdx) => {
        const cleaned = w.replace(/[^\p{L}\p{N}'’]/gu, "");
        const lower = cleaned.toLowerCase();
        const isFirst = idx === 0 && hIdx === 0;
        const isLast = idx === parts.length - 1 && hIdx === hyParts.length - 1;
        if (!cleaned) return w;
        if (!isFirst && !isLast && lowerWords.has(lower)) return w.replace(cleaned, lower);
        const cap = lower.charAt(0).toUpperCase() + lower.slice(1);
        return w.replace(cleaned, cap);
      });
      return rebuilt.join("-");
    }).join("");
  }

  function displayTitleFor(artistRaw, titleRaw){
    const clean = stripTitleSuffixes(titleRaw);
    return titleCaseEN(clean || "—");
  }

  function coverHtmlByUrl(url, sizeClass = "w-12 h-12 rounded-2xl"){
    const u = String(url || "").trim();
    return `
      <div class="abfCover ${sizeClass} border border-white/10 overflow-hidden flex-none bg-black/20">
        <img src="${u ? esc(u) : ""}" alt="" class="${u ? "w-full h-full object-cover" : "hidden"}" loading="lazy" decoding="async" />
        <div class="abfCoverFallback w-full h-full grid place-items-center">
          <img src="/logo-abf.png" alt="ABF" loading="lazy" decoding="async" class="w-8 h-8 opacity-90" />
        </div>
      </div>
    `;
  }

  function rememberCover(norm, url){
    const n = String(norm || "").trim();
    const u = String(url || "").trim();
    if (!n || !u) return;
    state.coverMemory[n] = u;
  }

  function getRememberedCover(norm){
    const n = String(norm || "").trim();
    return n ? String(state.coverMemory[n] || "") : "";
  }

  async function fetchServerNowPlaying(limit = 400){
    try{
      const res = await fetch(`/api/nowplaying?limit=${limit}`, { cache: "no-store" });
      const data = await res.json().catch(()=> ({}));
      if (!data?.ok) return { now: null, history: [] };

      let now = null;
      if (data?.now) {
        const rawNow = String(data?.now?.raw || "").trim();
        const a = String(data?.now?.artist || "").trim();
        const t = String(data?.now?.title || "").trim();
        const raw = rawNow || (a || t ? `${a} - ${t}`.trim() : "");
        if (raw) {
          now = {
            t: raw,
            ts:
              Number(data?.now?.played_at_ms) ||
              (data?.now?.played_at ? new Date(data.now.played_at).getTime() : Date.now()),
            cover_url: String(data?.now?.cover_url || ""),
            cover_source: String(data?.now?.cover_source || ""),
            is_new: Boolean(data?.now?.is_new),
            first_played_at_ms: Number(data?.now?.first_played_at_ms || 0),
          };
        }
      }

      const history = [];
      if (Array.isArray(data?.history)){
        for (const row of data.history){
          const raw = String(row?.raw || `${row?.artist || ""} - ${row?.title || ""}`.trim() || "").trim();
          if (!raw) continue;
          history.push({
            t: raw,
            ts: Number(row?.played_at_ms) || (row?.played_at ? new Date(row.played_at).getTime() : 0),
            cover_url: String(row?.cover_url || ""),
            cover_source: String(row?.cover_source || ""),
            is_new: Boolean(row?.is_new),
            first_played_at_ms: Number(row?.first_played_at_ms || 0),
          });
        }
      }

      return { now, history };
    }catch{
      return { now: null, history: [] };
    }
  }

  function setCover(url, root){
    const img = root?.querySelector("#musicCover");
    if (!img) return;
    const u = String(url || "").trim();
    if (u){
      img.src = u;
      img.classList.remove("hidden");
    } else {
      img.removeAttribute("src");
      img.classList.add("hidden");
    }
  }

  function inferCoverSource(coverUrl, explicitSource){
    const src = String(explicitSource || "").toLowerCase().trim();
    const u = String(coverUrl || "").toLowerCase().trim();

    if (src.includes("directus")) return "directus";
    if (src.includes("itunes") || src.includes("apple")) return "itunes";
    if (u.includes("mzstatic.com")) return "itunes";
    if (u.includes("/assets/") || u.includes("directus")) return "directus";

    if (!u) return "none";
    return "other";
  }

  function setCoverSourceBadge(root, coverUrl, explicitSource){
    const el = root?.querySelector("#npCoverSource");
    if (!el) return;

    const kind = inferCoverSource(coverUrl, explicitSource);

    el.className = "inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-semibold border tabular-nums";
    el.textContent =
      kind === "directus" ? "Directus cover" :
      kind === "itunes"   ? "iTunes cover"   :
      "No cover";

    if (kind === "directus") el.classList.add("directus");
    if (kind === "itunes") el.classList.add("itunes");
    if (kind === "other") el.classList.add("other");
    if (kind === "none") el.classList.add("none");

    el.classList.remove("hidden");
  }

  function rotationBadgeHtml(plays){
    const n = Number(plays || 0);
    if (n >= 6) return `<span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-[11px] font-extrabold border bg-amber-500/12 border-amber-400/25 text-amber-200">Heavy rotation</span>`;
    if (n >= 4) return `<span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-[11px] font-extrabold border bg-rose-500/12 border-rose-400/25 text-rose-200">Hot rotation</span>`;
    if (n >= 2) return `<span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-[11px] font-extrabold border bg-cyan-500/10 border-cyan-400/20 text-cyan-100">Recurrent</span>`;
    return "";
  }

  function trendBadgeHtml(delta){
    const d = Number(delta || 0);
    if (d > 0) return `<div class="inline-flex items-center justify-center px-2 py-1 rounded-full text-[11px] font-extrabold border bg-emerald-500/12 border-emerald-400/25 text-emerald-200 mb-1">Rising +${d}</div>`;
    if (d < 0) return `<div class="inline-flex items-center justify-center px-2 py-1 rounded-full text-[11px] font-extrabold border bg-rose-500/12 border-rose-400/25 text-rose-200 mb-1">Falling ${d}</div>`;
    return `<div class="inline-flex items-center justify-center px-2 py-1 rounded-full text-[11px] font-extrabold border bg-white/5 border-white/10 text-white/60 mb-1">Stable</div>`;
  }

  function rankBadgeClass(rank){
    if (rank === 1) return "bg-amber-400/15 border-amber-300/30 text-amber-200";
    if (rank === 2) return "bg-slate-200/10 border-slate-200/25 text-slate-100";
    if (rank === 3) return "bg-orange-400/15 border-orange-300/30 text-orange-200";
    return "bg-cyan-500/10 border-cyan-400/20 text-cyan-100";
  }

  function newBadgeHtml(){
    return `<span class="inline-flex items-center justify-center px-2.5 py-1 rounded-full text-[11px] font-extrabold border bg-rose-500/15 border-rose-400/30 text-rose-100 tracking-wide flex-none">NEW</span>`;
  }

  function chartRowHtml(rank, coverUrl, artist, title, count, max, unitLabel = "plays", isNew = false, secondaryBadge = ""){
    const pct = Math.round((Number(count) / Math.max(1, Number(max))) * 100);
    return `
      <li class="group flex items-center gap-4 p-4 rounded-3xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.05] transition">
        <div class="flex-none w-10 h-10 rounded-2xl border ${rankBadgeClass(rank)} flex items-center justify-center text-sm font-extrabold tabular-nums">
          ${rank}
        </div>
        ${coverHtmlByUrl(coverUrl)}
        <div class="min-w-0 flex-1">
          <div class="flex items-start gap-3">
            <div class="min-w-0">
              <div class="font-extrabold text-white truncate">${esc(artist)}</div>
              <div class="mt-1 flex items-center gap-2 min-w-0">
                <div class="text-white/65 text-sm truncate min-w-0">${esc(title)}</div>
                ${isNew ? newBadgeHtml() : ""}
              </div>
            </div>
            <div class="ml-auto flex-none flex items-center gap-2 text-sm text-white/90 font-extrabold tabular-nums">
              ${secondaryBadge}
              <span>${esc(String(count))} <span class="text-white/50 font-normal">${esc(unitLabel)}</span></span>
            </div>
          </div>
          <div class="mt-3 h-2 rounded-full bg-white/5 border border-white/10 overflow-hidden">
            <div class="h-full bg-gradient-to-r from-[#145C8F] to-[#2FC2FF]" style="width:${pct}%"></div>
          </div>
        </div>
      </li>
    `;
  }

  function compactMetricRowHtml({ rank, coverUrl, artist, title, metricValue, metricLabel, subline = "", accent = "cyan", isNew = false, rightBadge = "" }){
    const accentClass =
      accent === "emerald"
        ? "bg-emerald-500/10 border-emerald-400/20 text-emerald-100"
        : accent === "rose"
        ? "bg-rose-500/10 border-rose-400/20 text-rose-100"
        : "bg-cyan-500/10 border-cyan-400/20 text-cyan-100";

    return `
      <div class="flex items-center gap-3 p-3 rounded-2xl border border-white/10 bg-white/[0.03] hover:bg-white/[0.05] transition">
        <div class="flex-none w-9 h-9 rounded-2xl border ${accentClass} flex items-center justify-center text-sm font-extrabold tabular-nums">
          ${esc(String(rank))}
        </div>
        ${coverHtmlByUrl(coverUrl, "w-12 h-12 rounded-2xl")}
        <div class="min-w-0 flex-1">
          <div class="font-extrabold text-white truncate">${esc(artist)}</div>
          <div class="mt-1 flex items-center gap-2 min-w-0">
            <div class="text-white/65 text-sm truncate min-w-0 flex-1">${esc(title)}</div>
            ${isNew ? newBadgeHtml() : ""}
          </div>
          ${subline ? `<div class="text-xs text-white/45 mt-1 truncate">${esc(subline)}</div>` : ""}
        </div>
        <div class="flex-none text-right">
          ${rightBadge || ""}
          <div class="text-sm font-extrabold text-white tabular-nums">${esc(String(metricValue))}</div>
          <div class="text-[11px] text-white/45 uppercase tracking-wide">${esc(metricLabel)}</div>
        </div>
      </div>
    `;
  }

  function newEntryCardHtml({ coverUrl, artist, title, firstSeen, plays, isNew }){
    return `
      <div class="rounded-2xl border border-white/10 bg-white/[0.03] p-4 hover:bg-white/[0.05] transition">
        <div class="flex items-start gap-4">
          ${coverHtmlByUrl(coverUrl, "w-16 h-16 rounded-2xl")}
          <div class="min-w-0 flex-1">
            <div class="flex items-start gap-2">
              <div class="min-w-0 flex-1">
                <div class="font-extrabold text-white truncate">${esc(artist)}</div>
                <div class="mt-1 flex items-center gap-2 min-w-0">
                  <div class="text-white/65 text-sm truncate min-w-0 flex-1">${esc(title)}</div>
                  ${isNew ? newBadgeHtml() : ""}
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="text-xs text-white/45">
                ${esc(fmtRelativeSince(firstSeen))} • <span class="tabular-nums">${esc(fmtDateTimeShort(firstSeen))}</span>
              </div>
              <div class="text-xs text-white/70 border border-white/10 bg-white/5 px-2.5 py-1 rounded-xl tabular-nums">
                ${esc(String(plays))} plays
              </div>
            </div>
          </div>
        </div>
      </div>
    `;
  }

  function buildAirplayStats(history, coverByNorm){
    const now = nowTs();
    const todayStart = startOfLocalDay(now);
    const last24hStart = now - DAY;
    const prev24hStart = now - (2 * DAY);
    const map = Object.create(null);
    const dedupe = new Set();

    for (const entry of (history || [])){
      const ts = Number(entry?.ts || 0);
      const rawTrack = String(entry?.t || "").trim();
      if (!rawTrack || !ts) continue;

      const minuteKey = `${rawTrack.toLowerCase()}_${Math.floor(ts / 60000)}`;
      if (dedupe.has(minuteKey)) continue;
      dedupe.add(minuteKey);

      const sp = splitTrack(rawTrack);
      const aRaw = String(sp.artist || "").trim();
      const tRaw = String(sp.title || "").trim();
      const n = normKey(aRaw, tRaw);
      if (!n) continue;

      if (!map[n]){
        map[n] = {
          norm: n,
          artist: aRaw,
          title: tRaw,
          coverUrl:
            String(entry?.cover_url || "").trim() ||
            String(coverByNorm?.[n] || "").trim() ||
            getRememberedCover(n),
          plays: 0,
          playsToday: 0,
          plays24h: 0,
          playsPrev24h: 0,
          latestTs: 0,
          firstSeen: Number(entry?.first_played_at_ms || 0) || ts || now,
          isNew: Boolean(entry?.is_new),
        };
      }

      const item = map[n];
      item.plays += 1;
      if (ts >= todayStart) item.playsToday += 1;
      if (ts >= last24hStart) item.plays24h += 1;
      else if (ts >= prev24hStart) item.playsPrev24h += 1;

      if (ts > item.latestTs) item.latestTs = ts;

      const serverFirstSeen = Number(entry?.first_played_at_ms || 0);
      if (serverFirstSeen) item.firstSeen = serverFirstSeen;
      else if (ts) item.firstSeen = Math.min(item.firstSeen, ts);

      if (entry?.is_new) item.isNew = true;

      if (!item.coverUrl){
        item.coverUrl =
          String(entry?.cover_url || "").trim() ||
          String(coverByNorm?.[n] || "").trim() ||
          getRememberedCover(n);
      }
    }

    const rows = Object.values(map);

    const mostPlayed = rows
      .slice()
      .sort((a, b) => Number(b.plays || 0) - Number(a.plays || 0) || Number(b.latestTs || 0) - Number(a.latestTs || 0))
      .slice(0, 10);

    const today = rows
      .filter((x) => Number(x.playsToday || 0) > 0)
      .sort((a, b) => Number(b.playsToday || 0) - Number(a.playsToday || 0) || Number(b.latestTs || 0) - Number(a.latestTs || 0))
      .slice(0, 10);

    const trending = rows
      .map((x) => ({
        ...x,
        delta24: Number(x.plays24h || 0) - Number(x.playsPrev24h || 0),
      }))
      .filter((x) => Number(x.plays24h || 0) > 0 || Number(x.playsPrev24h || 0) > 0)
      .sort((a, b) =>
        Number(b.delta24 || 0) - Number(a.delta24 || 0) ||
        Number(b.plays24h || 0) - Number(a.plays24h || 0) ||
        Number(b.latestTs || 0) - Number(a.latestTs || 0)
      )
      .slice(0, 10);

    const newEntries = rows
      .filter((x) => Boolean(x.isNew))
      .sort((a, b) => Number(b.firstSeen || 0) - Number(a.firstSeen || 0) || Number(b.latestTs || 0) - Number(a.latestTs || 0))
      .slice(0, 12);

    return { mostPlayed, today, trending, newEntries };
  }

  function setQuickCard(idTrack, idCount, row, labelBuilder){
    const root = getRoot();
    if (!root) return;
    const trackEl = root.querySelector(idTrack);
    const countEl = root.querySelector(idCount);
    if (!trackEl || !countEl) return;

    if (!row){
      trackEl.textContent = "—";
      countEl.textContent = "—";
      return;
    }

    trackEl.textContent = `${upperArtist(row.artist || "—")} — ${displayTitleFor(row.artist || "", row.title || "")}`;
    countEl.textContent = labelBuilder(row);
  }

  async function render(){
    if (!isInsightsRoute()) return;
    const root = getRoot();
    if (!root) return;
    if (state.inFlight) return;
    state.inFlight = true;

    try{
      const artistEl = root.querySelector("#musicArtist");
      const titleEl = root.querySelector("#musicTitle");
      const timeEl = root.querySelector("#musicTime");
      const npNewBadge = root.querySelector("#npNewBadge");

      const autoMostPlayedEl = root.querySelector("#autoMostPlayed");
      const autoMostPlayedEmpty = root.querySelector("#autoMostPlayedEmpty");
      const autoTrendingEl = root.querySelector("#autoTrending");
      const autoTrendingEmpty = root.querySelector("#autoTrendingEmpty");
      const autoTodayEl = root.querySelector("#autoToday");
      const autoTodayEmpty = root.querySelector("#autoTodayEmpty");
      const autoNewEntriesEl = root.querySelector("#autoNewEntries");
      const autoNewEntriesEmpty = root.querySelector("#autoNewEntriesEmpty");

      const serverData = await fetchServerNowPlaying(400);
      const history = serverData.history || [];
      const nowEntry = serverData.now || history[0] || null;

      const coverByNorm = {};
      for (const entry of history){
        const t = splitTrack(entry.t);
        const n = normKey(t.artist, t.title);
        const u = String(entry.cover_url || "").trim();
        if (!n) continue;
        if (u) rememberCover(n, u);
        coverByNorm[n] = u || getRememberedCover(n) || "";
      }

      if (artistEl && titleEl && nowEntry){
        const current = splitTrack(nowEntry?.t || "");
        const nowArtistRaw = String(current.artist || "").trim();
        const nowTitleRaw = String(current.title || "").trim();
        const nowKNorm = normKey(nowArtistRaw, nowTitleRaw);

        artistEl.textContent = upperArtist(nowArtistRaw || "—");
        titleEl.textContent = displayTitleFor(nowArtistRaw, nowTitleRaw);
        if (timeEl) timeEl.textContent = fmtTime(Number(nowEntry?.ts || 0));

        const nowCover =
          String(nowEntry?.cover_url || "").trim() ||
          coverByNorm[nowKNorm] ||
          getRememberedCover(nowKNorm);

        if (nowCover) rememberCover(nowKNorm, nowCover);
        setCover(nowCover, root);
        setCoverSourceBadge(root, nowCover, String(nowEntry?.cover_source || ""));

        if (npNewBadge){
          if (Boolean(nowEntry?.is_new)) {
            npNewBadge.classList.remove("hidden");
            npNewBadge.classList.add("inline-flex");
          } else {
            npNewBadge.classList.add("hidden");
            npNewBadge.classList.remove("inline-flex");
          }
        }
      } else {
        if (artistEl) artistEl.textContent = "—";
        if (titleEl) titleEl.textContent = "—";
        if (timeEl) timeEl.textContent = "--:--";
        setCover("", root);
        setCoverSourceBadge(root, "", "");
        if (npNewBadge) npNewBadge.classList.add("hidden");
      }

      const airplayStats = buildAirplayStats(history, coverByNorm);

      setQuickCard("#quickTodayTrack", "#quickTodayCount", airplayStats.today[0], (row) => `${Number(row.playsToday || 0)} plays today`);
      setQuickCard("#quickTrendTrack", "#quickTrendCount", airplayStats.trending[0], (row) => {
        const d = Number(row.delta24 || 0);
        return `24h delta ${d >= 0 ? "+" : ""}${d}`;
      });
      setQuickCard("#quickNewTrack", "#quickNewCount", airplayStats.newEntries[0], (row) => fmtRelativeSince(row.firstSeen));

      const autoHash = JSON.stringify({
        now: nowEntry ? [nowEntry.t, nowEntry.ts, nowEntry.cover_url, nowEntry.is_new] : [],
        mostPlayed: airplayStats.mostPlayed.map(x => [x.norm, x.plays, x.coverUrl, x.isNew]),
        trending: airplayStats.trending.map(x => [x.norm, x.plays24h, x.playsPrev24h, x.coverUrl, x.isNew]),
        today: airplayStats.today.map(x => [x.norm, x.playsToday, x.coverUrl, x.isNew]),
        newEntries: airplayStats.newEntries.map(x => [x.norm, x.firstSeen, x.coverUrl, x.isNew]),
      });

      if (state.lastAutoHash !== autoHash) {
        state.lastAutoHash = autoHash;

        if (autoMostPlayedEl){
          if (!airplayStats.mostPlayed.length){
            if (autoMostPlayedEmpty) autoMostPlayedEmpty.classList.remove("hidden");
            autoMostPlayedEl.innerHTML = "";
          } else {
            if (autoMostPlayedEmpty) autoMostPlayedEmpty.classList.add("hidden");
            const maxAuto = Math.max(...airplayStats.mostPlayed.map(x => Number(x.plays || 0)), 1);
            autoMostPlayedEl.innerHTML = airplayStats.mostPlayed.map((row, idx) => {
              if (row.coverUrl) rememberCover(row.norm, row.coverUrl);
              return chartRowHtml(
                idx + 1,
                row.coverUrl || "",
                upperArtist(row.artist || "—"),
                displayTitleFor(row.artist || "", row.title || ""),
                Number(row.plays || 0),
                maxAuto,
                "plays",
                Boolean(row.isNew),
                rotationBadgeHtml(Number(row.plays || 0))
              );
            }).join("");
          }
        }

        if (autoTrendingEl){
          if (!airplayStats.trending.length){
            if (autoTrendingEmpty) autoTrendingEmpty.classList.remove("hidden");
            autoTrendingEl.innerHTML = "";
          } else {
            if (autoTrendingEmpty) autoTrendingEmpty.classList.add("hidden");
            autoTrendingEl.innerHTML = airplayStats.trending.map((row, idx) => {
              if (row.coverUrl) rememberCover(row.norm, row.coverUrl);
              const delta = Number(row.delta24 || 0);
              return compactMetricRowHtml({
                rank: idx + 1,
                coverUrl: row.coverUrl || "",
                artist: upperArtist(row.artist || "—"),
                title: displayTitleFor(row.artist || "", row.title || ""),
                metricValue: Number(row.plays24h || 0),
                metricLabel: "24h plays",
                subline: `Previous 24h: ${Number(row.playsPrev24h || 0)} • Delta: ${delta >= 0 ? "+" : ""}${delta}`,
                accent: "emerald",
                isNew: Boolean(row.isNew),
                rightBadge: trendBadgeHtml(delta),
              });
            }).join("");
          }
        }

        if (autoTodayEl){
          if (!airplayStats.today.length){
            if (autoTodayEmpty) autoTodayEmpty.classList.remove("hidden");
            autoTodayEl.innerHTML = "";
          } else {
            if (autoTodayEmpty) autoTodayEmpty.classList.add("hidden");
            autoTodayEl.innerHTML = airplayStats.today.map((row, idx) => {
              if (row.coverUrl) rememberCover(row.norm, row.coverUrl);
              return compactMetricRowHtml({
                rank: idx + 1,
                coverUrl: row.coverUrl || "",
                artist: upperArtist(row.artist || "—"),
                title: displayTitleFor(row.artist || "", row.title || ""),
                metricValue: Number(row.playsToday || 0),
                metricLabel: "today",
                subline: `Latest spin • ${fmtTime(row.latestTs)}`,
                accent: "cyan",
                isNew: Boolean(row.isNew),
                rightBadge: "",
              });
            }).join("");
          }
        }

        if (autoNewEntriesEl){
          if (!airplayStats.newEntries.length){
            if (autoNewEntriesEmpty) autoNewEntriesEmpty.classList.remove("hidden");
            autoNewEntriesEl.innerHTML = "";
          } else {
            if (autoNewEntriesEmpty) autoNewEntriesEmpty.classList.add("hidden");
            autoNewEntriesEl.innerHTML = airplayStats.newEntries.map((row) => {
              if (row.coverUrl) rememberCover(row.norm, row.coverUrl);
              return newEntryCardHtml({
                coverUrl: row.coverUrl || "",
                artist: upperArtist(row.artist || "—"),
                title: displayTitleFor(row.artist || "", row.title || ""),
                firstSeen: row.firstSeen,
                plays: Number(row.plays || 0),
                isNew: true,
              });
            }).join("");
          }
        }
      }

      state.lastRenderAt = nowTs();
    } finally {
      state.inFlight = false;
    }
  }

  function stopTimer(){
    if (state.timer) clearInterval(state.timer);
    state.timer = null;
  }

  function startTimer(){
    stopTimer();
    state.timer = setInterval(() => {
      if (state.inFlight) return;
      render();
    }, 8000);
  }

  function init(){
    if (!isInsightsRoute()) return;
    const root = getRoot();
    if (!root) return;
    state.lastAutoHash = "";
    render();
    startTimer();
  }

  if (!state.bound){
    state.bound = true;
    document.addEventListener("astro:page-load", init);
    document.addEventListener("astro:after-swap", init);
    document.addEventListener("astro:before-swap", () => {
      stopTimer();
    });
    window.addEventListener("resize", () => {
      if (!isInsightsRoute()) return;
      const t = nowTs();
      if (t - state.lastRenderAt > 400) render();
    });
  }

  init();
})();
    </script>
  </div>
</Base>