---
import Base from "../layouts/Base.astro";
export const prerender = false;
---

<Base
  title="RadioABF Studio Monitoring — RadioABF"
  description="Real-time audio tools and live player analysis on RadioABF."
  canonical="/studio"
  image="/og-image.jpg"
>
  <div id="studioPageRoot">
    <!-- HERO -->
    <section class="relative overflow-hidden rounded-3xl border border-white/10 bg-[#0A1F33] p-5 sm:p-6 mb-6 shadow-2xl">
      <div class="pointer-events-none absolute -top-40 -left-40 w-[520px] h-[520px] rounded-full bg-cyan-500/15 blur-[120px]"></div>
      <div class="pointer-events-none absolute -bottom-40 -right-40 w-[520px] h-[520px] rounded-full bg-blue-500/15 blur-[120px]"></div>
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(47,194,255,0.10),transparent_35%),radial-gradient(circle_at_bottom_right,rgba(59,130,246,0.10),transparent_30%)]"></div>

      <div class="relative z-10 grid grid-cols-1 xl:grid-cols-[1.2fr_.8fr] gap-5 items-start">
        <div class="min-w-0">
          <div class="inline-flex w-fit items-center gap-2 rounded-full border border-cyan-400/25 bg-cyan-400/10 px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.18em] text-cyan-200">
            <span class="relative flex h-2.5 w-2.5">
              <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-cyan-300 opacity-75"></span>
              <span class="relative inline-flex h-2.5 w-2.5 rounded-full bg-cyan-300"></span>
            </span>
            Live Audio Tools
          </div>

          <h1 class="mt-4 text-3xl sm:text-4xl lg:text-5xl font-extrabold tracking-tight text-white">
            <span class="text-white">RadioABF</span>
            <span class="bg-gradient-to-r from-cyan-300 via-cyan-400 to-blue-400 bg-clip-text text-transparent"> Studio Monitoring</span>
          </h1>

          <p class="mt-3 text-sm sm:text-base text-white/72 leading-relaxed max-w-2xl">
            Premium real-time monitoring of the RadioABF player output with live metering, spectrum analysis, waveform tracking and stereo field intelligence.
          </p>

          <div class="mt-5 flex flex-wrap gap-2">
            <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] uppercase tracking-wider text-white/70">
              Player-linked
            </span>
            <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] uppercase tracking-wider text-white/70">
              Persistent Graph
            </span>
            <span class="inline-flex items-center rounded-full border border-white/10 bg-white/5 px-3 py-1 text-[11px] uppercase tracking-wider text-white/70">
              Realtime
            </span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-3">
          <div class="rounded-2xl border border-white/10 bg-white/[0.05] p-4">
            <div class="text-[11px] uppercase tracking-[0.16em] text-cyan-200/85 font-semibold">
              Live status
            </div>
            <div id="heroPlayerState" class="mt-2 text-base sm:text-lg font-bold text-white">—</div>
            <div class="mt-1 text-xs text-white/50">Global player bridge</div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.05] p-4">
            <div class="text-[11px] uppercase tracking-[0.16em] text-cyan-200/85 font-semibold">
              Audio context
            </div>
            <div id="heroAudioCtxState" class="mt-2 text-base sm:text-lg font-bold text-white">—</div>
            <div class="mt-1 text-xs text-white/50">Realtime engine</div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-white/[0.05] p-4 col-span-2">
            <div class="text-[11px] uppercase tracking-[0.16em] text-cyan-200/85 font-semibold">
              Live strip
            </div>
            <div class="mt-3 grid grid-cols-3 gap-3">
              <div>
                <div class="flex items-center justify-between gap-2 text-[11px] text-white/45 uppercase tracking-wider">
                  <span>Peak</span>
                  <span id="heroPeakText" class="text-white/70 normal-case tracking-normal">—</span>
                </div>
                <div class="mt-2 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
                  <div id="heroPeakBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
                </div>
              </div>

              <div>
                <div class="flex items-center justify-between gap-2 text-[11px] text-white/45 uppercase tracking-wider">
                  <span>RMS</span>
                  <span id="heroRmsText" class="text-white/70 normal-case tracking-normal">—</span>
                </div>
                <div class="mt-2 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
                  <div id="heroRmsBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
                </div>
              </div>

              <div>
                <div class="flex items-center justify-between gap-2 text-[11px] text-white/45 uppercase tracking-wider">
                  <span>Focus</span>
                  <span id="heroFocusText" class="text-white/70 normal-case tracking-normal">—</span>
                </div>
                <div class="mt-2 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
                  <div id="heroFocusBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ROW 1 -->
    <section class="grid grid-cols-1 xl:grid-cols-[1.02fr_.98fr] gap-6 mb-6">
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between gap-3 mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Audio Bridge
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              Player Connection
            </h2>
          </div>

          <div
            id="studioBridgeBadge"
            class="inline-flex items-center justify-center px-3 py-1 rounded-xl border border-white/10 bg-white/5 text-[11px] uppercase tracking-wider text-white/70"
          >
            waiting
          </div>
        </div>

        <div class="grid grid-cols-2 lg:grid-cols-4 gap-3">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-[11px] text-white/45 uppercase tracking-wider">Audio</div>
            <div id="studioAudioState" class="mt-2 text-sm font-semibold text-white/85">—</div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-[11px] text-white/45 uppercase tracking-wider">Context</div>
            <div id="studioCtxState" class="mt-2 text-sm font-semibold text-white/85">—</div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-[11px] text-white/45 uppercase tracking-wider">Analyser</div>
            <div id="studioAnalyserState" class="mt-2 text-sm font-semibold text-white/85">—</div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-[11px] text-white/45 uppercase tracking-wider">State</div>
            <div id="studioPlayerState" class="mt-2 text-sm font-semibold text-white/85">—</div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
          Live Output
        </div>
        <h2 class="mt-1 text-xl font-bold text-white">
          Now Playing Mirror
        </h2>

        <div class="mt-4 flex items-center gap-4">
          <div class="abfCover w-20 h-20 rounded-2xl border border-white/10 overflow-hidden flex-none">
            <img id="studioCover" class="hidden" alt="Current cover" />
            <div id="studioCoverFallback" class="abfCoverFallback">
              <img src="/logo-abf.png" alt="ABF" loading="lazy" decoding="async" />
            </div>
          </div>

          <div class="min-w-0">
            <div id="studioArtist" class="font-semibold text-sm text-white truncate">—</div>
            <div id="studioTitle" class="mt-1 text-sm text-white/65 truncate">—</div>
          </div>
        </div>

        <div class="mt-5 grid grid-cols-2 gap-3">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Peak</div>
              <div id="studioPeakText" class="text-sm font-semibold text-white/85">—</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="studioPeakBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">RMS</div>
              <div id="studioRmsText" class="text-sm font-semibold text-white/85">—</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="studioRmsBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ROW 2 -->
    <section class="grid grid-cols-1 2xl:grid-cols-[.9fr_1.1fr] gap-6 mb-6">
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Signal Level
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              VU Meter
            </h2>
          </div>

          <div class="text-xs text-white/45">Live</div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-end justify-center gap-3 h-40">
              <div class="w-full max-w-[96px] h-full rounded-xl border border-white/10 bg-black/40 p-2">
                <div class="relative h-full w-full overflow-hidden rounded-lg bg-[linear-gradient(180deg,rgba(239,68,68,0.14)_0%,rgba(250,204,21,0.12)_28%,rgba(34,197,94,0.10)_100%)]">
                  <div
                    id="vuLeft"
                    class="absolute inset-x-0 bottom-0 rounded-b-lg bg-gradient-to-t from-cyan-500 via-blue-400 to-cyan-200 shadow-[0_0_35px_rgba(47,194,255,0.28)] transition-[height] duration-75"
                    style="height:0%;"
                  ></div>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Left</div>
              <div id="vuLeftValue" class="text-xs text-white/60">0%</div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-end justify-center gap-3 h-40">
              <div class="w-full max-w-[96px] h-full rounded-xl border border-white/10 bg-black/40 p-2">
                <div class="relative h-full w-full overflow-hidden rounded-lg bg-[linear-gradient(180deg,rgba(239,68,68,0.14)_0%,rgba(250,204,21,0.12)_28%,rgba(34,197,94,0.10)_100%)]">
                  <div
                    id="vuRight"
                    class="absolute inset-x-0 bottom-0 rounded-b-lg bg-gradient-to-t from-cyan-500 via-blue-400 to-cyan-200 shadow-[0_0_35px_rgba(47,194,255,0.28)] transition-[height] duration-75"
                    style="height:0%;"
                  ></div>
                </div>
              </div>
            </div>
            <div class="mt-3 flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Right</div>
              <div id="vuRightValue" class="text-xs text-white/60">0%</div>
            </div>
          </div>
        </div>

        <div class="mt-4 rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
          <div class="flex items-center justify-between gap-3">
            <div class="text-xs text-white/45 uppercase tracking-wider">Dominant zone</div>
            <div id="dominantBandText" class="text-sm font-semibold text-white/85">—</div>
          </div>
          <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
            <div id="dominantBandBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Frequency Analysis
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              Spectrum Analyzer
            </h2>
          </div>

          <div class="text-xs text-white/45">Live</div>
        </div>

        <canvas
          id="spectrumCanvas"
          width="1200"
          height="360"
          class="w-full h-[220px] rounded-xl border border-white/10 bg-black/40"
        ></canvas>

        <div class="mt-3 flex items-center justify-between text-[11px] text-white/40 uppercase tracking-wider">
          <span>Low</span>
          <span>Mid</span>
          <span>High</span>
        </div>
      </div>
    </section>

    <!-- ROW 3 -->
    <section class="grid grid-cols-1 xl:grid-cols-[1fr_1.18fr_.82fr] gap-6 mb-6">
      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Time Domain
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              Waveform
            </h2>
          </div>

          <div class="text-xs text-white/45">Live</div>
        </div>

        <canvas
          id="waveformCanvas"
          width="1200"
          height="300"
          class="w-full h-[180px] rounded-xl border border-white/10 bg-black/40"
        ></canvas>

        <div class="mt-4 grid grid-cols-1 sm:grid-cols-2 gap-3">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-xs text-white/45 uppercase tracking-wider">Crest factor</div>
            <div id="crestFactorText" class="mt-2 text-sm font-semibold text-white/85">—</div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="crestFactorBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-xs text-white/45 uppercase tracking-wider">Signal profile</div>
            <div id="signalProfileText" class="mt-2 text-sm font-semibold text-white/85">—</div>
            <div class="mt-2 text-xs text-white/45">
              Dynamic feeling from peak vs RMS
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Stereo Field
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              Stereo Analyzer
            </h2>
          </div>

          <div class="text-xs text-white/45">Live</div>
        </div>

        <canvas
          id="stereoFieldCanvas"
          width="800"
          height="320"
          class="w-full h-[180px] rounded-xl border border-white/10 bg-black/40"
        ></canvas>

        <div class="mt-4 rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
          <div class="text-xs text-white/45 uppercase tracking-wider">Balance</div>
          <div class="mt-3 relative h-3 rounded-full bg-white/5 overflow-hidden border border-white/10">
            <div class="absolute inset-y-0 left-1/2 w-px bg-white/20"></div>
            <div
              id="stereoBalanceIndicator"
              class="absolute top-1/2 -translate-y-1/2 -translate-x-1/2 h-5 w-5 rounded-full border border-cyan-300/40 bg-cyan-300/20 shadow-[0_0_18px_rgba(47,194,255,0.30)] transition-[left] duration-100"
              style="left:50%;"
            ></div>
          </div>
          <div class="mt-3 flex items-center justify-between text-xs text-white/45 uppercase tracking-wider">
            <span>L</span>
            <span id="stereoBalanceText" class="text-white/70 normal-case tracking-normal">Centered</span>
            <span>R</span>
          </div>
        </div>

        <div class="mt-4 grid grid-cols-[1.2fr_.8fr] gap-4">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4 min-w-0">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Stereo width</div>
              <div id="stereoWidthText" class="text-sm font-semibold text-white/85 whitespace-nowrap">0%</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="stereoWidthBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4 min-w-0">
            <div class="text-xs text-white/45 uppercase tracking-wider">Phase feel</div>
            <div id="stereoPhaseText" class="mt-3 text-sm font-semibold text-white/85 whitespace-nowrap">—</div>
            <div class="mt-2 text-xs text-white/45">
              Stereo field state
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-3xl border border-white/10 bg-white/[0.04] p-5 sm:p-6 shadow-xl">
        <div class="flex items-center justify-between mb-4">
          <div>
            <div class="text-[11px] uppercase tracking-[0.18em] text-cyan-200/85 font-semibold">
              Frequency Bands
            </div>
            <h2 class="mt-1 text-xl font-bold text-white">
              Low / Mid / High
            </h2>
          </div>

          <div class="text-xs text-white/45">Energy</div>
        </div>

        <div class="space-y-4">
          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Low</div>
              <div id="bandLowText" class="text-sm font-semibold text-white/85">0%</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="bandLowBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">Mid</div>
              <div id="bandMidText" class="text-sm font-semibold text-white/85">0%</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="bandMidBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="flex items-center justify-between gap-3">
              <div class="text-xs text-white/45 uppercase tracking-wider">High</div>
              <div id="bandHighText" class="text-sm font-semibold text-white/85">0%</div>
            </div>
            <div class="mt-3 h-2 rounded-full bg-white/5 overflow-hidden border border-white/10">
              <div id="bandHighBar" class="h-full rounded-full bg-gradient-to-r from-cyan-500 to-blue-400 transition-[width] duration-100" style="width:0%"></div>
            </div>
          </div>

          <div class="rounded-2xl border border-white/10 bg-[#050B14]/70 p-4">
            <div class="text-xs text-white/45 uppercase tracking-wider">Spectral centroid</div>
            <div id="centroidText" class="mt-2 text-sm font-semibold text-white/85">—</div>
          </div>
        </div>
      </div>
    </section>
  </div>

  <script is:inline data-astro-rerun>
    (() => {
      const $ = (id) => document.getElementById(id);

      window.__abfStudioEngine = window.__abfStudioEngine || {
        raf: 0,
        active: false,
        attached: false,
        elems: {},
        stereoTrail: []
      };

      const E = window.__abfStudioEngine;

      function clamp(n, min, max) {
        return Math.max(min, Math.min(max, n));
      }

      function pageAlive() {
        return !!document.getElementById("studioPageRoot");
      }

      function onStudioPage() {
        return !!document.getElementById("studioPageRoot");
      }

      function captureElements() {
        return {
          root: $("studioPageRoot"),

          bridgeBadge: $("studioBridgeBadge"),
          audioState: $("studioAudioState"),
          ctxState: $("studioCtxState"),
          analyserState: $("studioAnalyserState"),
          playerState: $("studioPlayerState"),

          heroPlayerState: $("heroPlayerState"),
          heroAudioCtxState: $("heroAudioCtxState"),
          heroDominantBand: $("heroDominantBand"),
          heroDominantBar: $("heroDominantBar"),
          heroPeakText: $("heroPeakText"),
          heroPeakBar: $("heroPeakBar"),
          heroRmsText: $("heroRmsText"),
          heroRmsBar: $("heroRmsBar"),
          heroFocusText: $("heroFocusText"),
          heroFocusBar: $("heroFocusBar"),

          cover: $("studioCover"),
          coverFallback: $("studioCoverFallback"),
          artist: $("studioArtist"),
          title: $("studioTitle"),

          peakText: $("studioPeakText"),
          rmsText: $("studioRmsText"),
          peakBar: $("studioPeakBar"),
          rmsBar: $("studioRmsBar"),

          crestFactorText: $("crestFactorText"),
          crestFactorBar: $("crestFactorBar"),
          signalProfileText: $("signalProfileText"),

          vuLeft: $("vuLeft"),
          vuRight: $("vuRight"),
          vuLeftValue: $("vuLeftValue"),
          vuRightValue: $("vuRightValue"),

          spectrumCanvas: $("spectrumCanvas"),
          waveformCanvas: $("waveformCanvas"),
          stereoFieldCanvas: $("stereoFieldCanvas"),

          stereoBalanceIndicator: $("stereoBalanceIndicator"),
          stereoBalanceText: $("stereoBalanceText"),
          stereoWidthBar: $("stereoWidthBar"),
          stereoWidthText: $("stereoWidthText"),
          stereoPhaseText: $("stereoPhaseText"),

          bandLowBar: $("bandLowBar"),
          bandMidBar: $("bandMidBar"),
          bandHighBar: $("bandHighBar"),
          bandLowText: $("bandLowText"),
          bandMidText: $("bandMidText"),
          bandHighText: $("bandHighText"),
          centroidText: $("centroidText"),
          dominantBandText: $("dominantBandText"),
          dominantBandBar: $("dominantBandBar"),
        };
      }

      function elementsReady(elems) {
        return !!(
          elems.root &&
          elems.vuLeft &&
          elems.vuRight &&
          elems.spectrumCanvas &&
          elems.waveformCanvas &&
          elems.stereoFieldCanvas
        );
      }

      function attachToCurrentPage() {
        if (!onStudioPage()) {
          E.attached = false;
          E.elems = {};
          return false;
        }

        const elems = captureElements();
        if (!elementsReady(elems)) {
          E.attached = false;
          E.elems = {};
          return false;
        }

        E.elems = elems;
        E.attached = true;
        return true;
      }

      function resizeCanvasToDisplaySize(canvas) {
        if (!canvas) return;
        const dpr = window.devicePixelRatio || 1;
        const rect = canvas.getBoundingClientRect();
        const width = Math.max(1, Math.floor(rect.width * dpr));
        const height = Math.max(1, Math.floor(rect.height * dpr));
        if (canvas.width !== width || canvas.height !== height) {
          canvas.width = width;
          canvas.height = height;
        }
      }

      function syncBridge() {
        const elems = E.elems;
        const tools = window.__abfAudioTools;
        const graph = tools?.getAudioGraph?.();
        const state = tools?.getPlayerState?.();

        const hasAudio = !!graph?.audio;
        const hasCtx = !!graph?.audioCtx;
        const hasAnalyser = !!graph?.analyser;

        if (elems.bridgeBadge) {
          elems.bridgeBadge.textContent = hasAudio ? "connected" : "waiting";
          elems.bridgeBadge.className =
            "inline-flex items-center justify-center px-3 py-1 rounded-xl border text-[11px] uppercase tracking-wider " +
            (hasAudio
              ? "border-cyan-400/25 bg-cyan-400/10 text-cyan-200"
              : "border-white/10 bg-white/5 text-white/70");
        }

        if (elems.audioState) elems.audioState.textContent = hasAudio ? "Detected" : "Not detected";
        if (elems.ctxState) elems.ctxState.textContent = hasCtx ? (graph.audioCtx.state || "ready") : "Not initialized";
        if (elems.analyserState) elems.analyserState.textContent = hasAnalyser ? "Ready" : "Not initialized";

        let stateText = "Unavailable";
        if (state) {
          if (state.isStopped) stateText = "Stopped";
          else if (state.paused) stateText = "Paused";
          else if (state.muted) stateText = "Muted";
          else stateText = "Live";
        }

        if (elems.playerState) elems.playerState.textContent = stateText;
        if (elems.heroPlayerState) elems.heroPlayerState.textContent = stateText;
        if (elems.heroAudioCtxState) elems.heroAudioCtxState.textContent = hasCtx ? (graph.audioCtx.state || "ready") : "—";
      }

      function syncCoverPair(imgEl, fallbackEl, url) {
        if (!imgEl) return;

        imgEl.onerror = () => {
          imgEl.removeAttribute("src");
          imgEl.classList.add("hidden");
          if (fallbackEl) fallbackEl.style.display = "";
        };

        if (url) {
          imgEl.src = url;
          imgEl.classList.remove("hidden");
          if (fallbackEl) fallbackEl.style.display = "none";
        } else {
          imgEl.removeAttribute("src");
          imgEl.classList.add("hidden");
          if (fallbackEl) fallbackEl.style.display = "";
        }
      }

      function syncNowPlaying() {
        const elems = E.elems;
        const snap = window.__abfAudioTools?.getNowPlayingSnapshot?.() || {};
        const artist = snap.artist || "—";
        const title = snap.title || "—";
        const coverUrl = snap.cover || "";

        if (elems.artist) elems.artist.textContent = artist;
        if (elems.title) elems.title.textContent = title;
        syncCoverPair(elems.cover, elems.coverFallback, coverUrl);
      }

      function drawSpectrum(freqData) {
        const canvas = E.elems.spectrumCanvas;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        resizeCanvasToDisplaySize(canvas);
        const width = canvas.width;
        const height = canvas.height;

        ctx.clearRect(0, 0, width, height);

        const gradientBg = ctx.createLinearGradient(0, 0, 0, height);
        gradientBg.addColorStop(0, "rgba(47,194,255,0.05)");
        gradientBg.addColorStop(1, "rgba(5,11,20,0.0)");
        ctx.fillStyle = gradientBg;
        ctx.fillRect(0, 0, width, height);

        const bars = 84;
        const step = Math.max(1, Math.floor(freqData.length / bars));
        const gap = Math.max(2, Math.floor(width * 0.002));
        const barWidth = Math.max(3, Math.floor((width - gap * (bars - 1)) / bars));

        let x = 0;

        for (let i = 0; i < bars; i++) {
          const start = i * step;
          const end = Math.min(freqData.length, start + step);
          let sum = 0;

          for (let j = start; j < end; j++) sum += freqData[j] || 0;

          const avg = end > start ? sum / (end - start) : 0;
          const v = avg / 255;
          const barHeight = Math.max(2, Math.pow(v, 1.05) * height);

          const g = ctx.createLinearGradient(0, height - barHeight, 0, height);
          g.addColorStop(0, "rgba(233,248,255,0.98)");
          g.addColorStop(0.25, "rgba(129,212,250,0.96)");
          g.addColorStop(0.7, "rgba(59,130,246,0.95)");
          g.addColorStop(1, "rgba(6,182,212,0.95)");

          ctx.fillStyle = g;
          ctx.fillRect(x, height - barHeight, barWidth, barHeight);

          x += barWidth + gap;
          if (x > width) break;
        }

        ctx.strokeStyle = "rgba(255,255,255,0.07)";
        ctx.lineWidth = Math.max(1, width / 900);
        for (let i = 1; i <= 3; i++) {
          const y = (height / 4) * i;
          ctx.beginPath();
          ctx.moveTo(0, y);
          ctx.lineTo(width, y);
          ctx.stroke();
        }
      }

      function drawWaveform(timeData) {
        const canvas = E.elems.waveformCanvas;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        resizeCanvasToDisplaySize(canvas);
        const width = canvas.width;
        const height = canvas.height;

        ctx.clearRect(0, 0, width, height);

        const centerY = height / 2;

        ctx.strokeStyle = "rgba(255,255,255,0.08)";
        ctx.lineWidth = Math.max(1, width / 1100);
        ctx.beginPath();
        ctx.moveTo(0, centerY);
        ctx.lineTo(width, centerY);
        ctx.stroke();

        ctx.beginPath();
        for (let i = 0; i < timeData.length; i++) {
          const v = timeData[i] / 128.0;
          const y = (v * height) / 2;
          const x = (i / (timeData.length - 1)) * width;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.lineWidth = Math.max(6, width / 220);
        ctx.strokeStyle = "rgba(47,194,255,0.18)";
        ctx.stroke();

        ctx.beginPath();
        for (let i = 0; i < timeData.length; i++) {
          const v = timeData[i] / 128.0;
          const y = (v * height) / 2;
          const x = (i / (timeData.length - 1)) * width;
          if (i === 0) ctx.moveTo(x, y);
          else ctx.lineTo(x, y);
        }
        ctx.lineWidth = Math.max(2.5, width / 480);
        ctx.strokeStyle = "rgba(235,248,255,0.96)";
        ctx.stroke();
      }

      function drawStereoField(timeData) {
        const canvas = E.elems.stereoFieldCanvas;
        if (!canvas) return;
        const ctx = canvas.getContext("2d");
        if (!ctx) return;

        resizeCanvasToDisplaySize(canvas);
        const width = canvas.width;
        const height = canvas.height;

        ctx.clearRect(0, 0, width, height);

        const cx = width / 2;
        const cy = height / 2;
        const radius = Math.min(width, height) * 0.38;

        ctx.strokeStyle = "rgba(255,255,255,0.08)";
        ctx.lineWidth = Math.max(1, width / 1000);

        ctx.beginPath();
        ctx.moveTo(cx, 0);
        ctx.lineTo(cx, height);
        ctx.stroke();

        ctx.beginPath();
        ctx.moveTo(0, cy);
        ctx.lineTo(width, cy);
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(cx, cy, radius, 0, Math.PI * 2);
        ctx.stroke();

        ctx.beginPath();
        ctx.arc(cx, cy, radius * 0.55, 0, Math.PI * 2);
        ctx.stroke();

        const half = Math.floor(timeData.length / 2);

        for (let i = 0; i < half; i += 2) {
          const left = (timeData[i] - 128) / 128;
          const right = (timeData[i + half] - 128) / 128;

          const x = cx + (right - left) * radius * 0.95;
          const y = cy - (left + right) * radius * 0.55;

          const mag = Math.min(1, (Math.abs(left) + Math.abs(right)) * 0.9);
          E.stereoTrail.push({ x, y, mag, life: 1 });
        }

        if (E.stereoTrail.length > 220) {
          E.stereoTrail.splice(0, E.stereoTrail.length - 220);
        }

        E.stereoTrail = E.stereoTrail
          .map((p) => ({ ...p, life: p.life - 0.04 }))
          .filter((p) => p.life > 0);

        for (const p of E.stereoTrail) {
          const alpha = 0.03 + p.mag * 0.16 * p.life;
          const size = 0.8 + p.mag * 2.0 * p.life;
          ctx.fillStyle = `rgba(47,194,255,${alpha})`;
          ctx.beginPath();
          ctx.arc(p.x, p.y, size, 0, Math.PI * 2);
          ctx.fill();
        }
      }

      function updatePeakAndRms(timeData) {
        let peak = 0;
        let sum = 0;

        for (let i = 0; i < timeData.length; i++) {
          const v = Math.abs((timeData[i] - 128) / 128);
          if (v > peak) peak = v;
          sum += v * v;
        }

        const rms = Math.sqrt(sum / timeData.length);
        const peakPct = Math.round(clamp(peak, 0, 1) * 100);
        const rmsPct = Math.round(clamp(rms, 0, 1) * 100);

        if (E.elems.peakText) E.elems.peakText.textContent = `${peakPct}%`;
        if (E.elems.rmsText) E.elems.rmsText.textContent = `${rmsPct}%`;

        if (E.elems.heroPeakText) E.elems.heroPeakText.textContent = `${peakPct}%`;
        if (E.elems.heroRmsText) E.elems.heroRmsText.textContent = `${rmsPct}%`;

        if (E.elems.peakBar) E.elems.peakBar.style.width = `${peakPct}%`;
        if (E.elems.rmsBar) E.elems.rmsBar.style.width = `${rmsPct}%`;
        if (E.elems.heroPeakBar) E.elems.heroPeakBar.style.width = `${peakPct}%`;
        if (E.elems.heroRmsBar) E.elems.heroRmsBar.style.width = `${rmsPct}%`;

        const crestFactor = rms > 0 ? peak / rms : 0;
        const crestPct = Math.round(clamp((crestFactor - 1) / 2.5, 0, 1) * 100);

        if (E.elems.crestFactorText) E.elems.crestFactorText.textContent = crestFactor > 0 ? crestFactor.toFixed(2) : "—";
        if (E.elems.crestFactorBar) E.elems.crestFactorBar.style.width = `${crestPct}%`;

        if (E.elems.signalProfileText) {
          let profile = "Dense / steady";
          if (crestFactor > 2.1) profile = "Highly dynamic";
          else if (crestFactor > 1.65) profile = "Dynamic";
          else if (crestFactor > 1.3) profile = "Balanced";
          E.elems.signalProfileText.textContent = profile;
        }

        return { peak, rms, peakPct, rmsPct };
      }

      function updateVu(timeData) {
        const half = Math.floor(timeData.length / 2);
        let sumL = 0;
        let sumR = 0;

        for (let i = 0; i < half; i++) {
          const v = (timeData[i] - 128) / 128;
          sumL += v * v;
        }

        for (let i = half; i < timeData.length; i++) {
          const v = (timeData[i] - 128) / 128;
          sumR += v * v;
        }

        const rmsL = Math.sqrt(sumL / half);
        const rmsR = Math.sqrt(sumR / half);

        const levelL = clamp(rmsL * 3.2, 0, 1);
        const levelR = clamp(rmsR * 3.2, 0, 1);

        if (E.elems.vuLeft) E.elems.vuLeft.style.height = `${Math.max(4, levelL * 100)}%`;
        if (E.elems.vuRight) E.elems.vuRight.style.height = `${Math.max(4, levelR * 100)}%`;
        if (E.elems.vuLeftValue) E.elems.vuLeftValue.textContent = `${Math.round(levelL * 100)}%`;
        if (E.elems.vuRightValue) E.elems.vuRightValue.textContent = `${Math.round(levelR * 100)}%`;

        return { levelL, levelR };
      }

      function updateStereo(levelL, levelR) {
        const total = levelL + levelR;
        const balance = total > 0 ? (levelR - levelL) / total : 0;
        const balancePct = ((balance + 1) / 2) * 100;
        const width = clamp(Math.abs(levelR - levelL) * 180, 0, 100);

        if (E.elems.stereoBalanceIndicator) E.elems.stereoBalanceIndicator.style.left = `${balancePct}%`;
        if (E.elems.stereoWidthBar) E.elems.stereoWidthBar.style.width = `${Math.round(width)}%`;
        if (E.elems.stereoWidthText) E.elems.stereoWidthText.textContent = `${Math.round(width)}%`;

        if (E.elems.stereoBalanceText) {
          if (Math.abs(balance) < 0.08) E.elems.stereoBalanceText.textContent = "Centered";
          else if (balance < 0) E.elems.stereoBalanceText.textContent = `Left ${Math.round(Math.abs(balance) * 100)}%`;
          else E.elems.stereoBalanceText.textContent = `Right ${Math.round(Math.abs(balance) * 100)}%`;
        }

        if (E.elems.stereoPhaseText) {
          if (width < 12) E.elems.stereoPhaseText.textContent = "Near mono";
          else if (width < 35) E.elems.stereoPhaseText.textContent = "Moderate stereo";
          else if (width < 65) E.elems.stereoPhaseText.textContent = "Wide stereo";
          else E.elems.stereoPhaseText.textContent = "Very wide / separated";
        }
      }

      function averageRange(data, start, end) {
        const s = Math.max(0, start);
        const e = Math.min(data.length, end);
        if (e <= s) return 0;
        let sum = 0;
        for (let i = s; i < e; i++) sum += data[i];
        return sum / (e - s);
      }

      function updateBands(freqData, sampleRate, fftSize) {
        const binHz = sampleRate / fftSize;

        const lowEnd = Math.max(1, Math.floor(250 / binHz));
        const midEnd = Math.max(lowEnd + 1, Math.floor(4000 / binHz));
        const highEnd = freqData.length;

        const low = averageRange(freqData, 0, lowEnd) / 255;
        const mid = averageRange(freqData, lowEnd, midEnd) / 255;
        const high = averageRange(freqData, midEnd, highEnd) / 255;

        const lowPct = Math.round(low * 100);
        const midPct = Math.round(mid * 100);
        const highPct = Math.round(high * 100);

        if (E.elems.bandLowBar) E.elems.bandLowBar.style.width = `${lowPct}%`;
        if (E.elems.bandMidBar) E.elems.bandMidBar.style.width = `${midPct}%`;
        if (E.elems.bandHighBar) E.elems.bandHighBar.style.width = `${highPct}%`;

        if (E.elems.bandLowText) E.elems.bandLowText.textContent = `${lowPct}%`;
        if (E.elems.bandMidText) E.elems.bandMidText.textContent = `${midPct}%`;
        if (E.elems.bandHighText) E.elems.bandHighText.textContent = `${highPct}%`;

        let weightedSum = 0;
        let total = 0;
        for (let i = 0; i < freqData.length; i++) {
          const mag = freqData[i];
          const freq = i * binHz;
          weightedSum += freq * mag;
          total += mag;
        }

        const centroid = total > 0 ? weightedSum / total : 0;
        if (E.elems.centroidText) E.elems.centroidText.textContent = centroid > 0 ? `${Math.round(centroid)} Hz` : "—";

        const maxVal = Math.max(lowPct, midPct, highPct);
        let label = "Balanced";
        if (maxVal === lowPct) label = "Low / Bass";
        else if (maxVal === midPct) label = "Mid";
        else if (maxVal === highPct) label = "High";

        if (E.elems.dominantBandText) E.elems.dominantBandText.textContent = label;
        if (E.elems.heroDominantBand) E.elems.heroDominantBand.textContent = label;
        if (E.elems.heroFocusText) E.elems.heroFocusText.textContent = label;
        if (E.elems.dominantBandBar) E.elems.dominantBandBar.style.width = `${maxVal}%`;
        if (E.elems.heroDominantBar) E.elems.heroDominantBar.style.width = `${maxVal}%`;
        if (E.elems.heroFocusBar) E.elems.heroFocusBar.style.width = `${maxVal}%`;
      }

      function frameLoop() {
        if (!pageAlive()) {
          E.attached = false;
          E.elems = {};
          E.raf = requestAnimationFrame(frameLoop);
          return;
        }

        if (!E.attached || !elementsReady(E.elems)) {
          attachToCurrentPage();
        }

        if (E.attached) {
          const tools = window.__abfAudioTools;
          const graph = tools?.ensureAudioGraph?.();

          if (graph?.analyser && graph?.audioCtx) {
            const analyser = graph.analyser;
            const audioCtx = graph.audioCtx;

            analyser.fftSize = 2048;
            analyser.smoothingTimeConstant = 0.82;

            const freqData = new Uint8Array(analyser.frequencyBinCount);
            const timeData = new Uint8Array(analyser.fftSize);

            analyser.getByteFrequencyData(freqData);
            analyser.getByteTimeDomainData(timeData);

            syncBridge();
            syncNowPlaying();

            const { levelL, levelR } = updateVu(timeData);
            updateStereo(levelL, levelR);
            updatePeakAndRms(timeData);
            updateBands(freqData, audioCtx.sampleRate || 44100, analyser.fftSize || 2048);

            drawSpectrum(freqData);
            drawWaveform(timeData);
            drawStereoField(timeData);
          }
        }

        E.raf = requestAnimationFrame(frameLoop);
      }

      function ensureEngineRunning() {
        if (E.active) return;
        E.active = true;
        attachToCurrentPage();
        frameLoop();
      }

      function reattachStudio() {
        attachToCurrentPage();

        const tools = window.__abfAudioTools;
        const graph = tools?.getAudioGraph?.();

        if (graph?.audio && !graph?.analyser) {
          tools?.ensureAudioGraph?.();
        }

        if (!graph?.audio) {
          const globalAudio = window.__abf?.audio || null;
          if (globalAudio) {
            tools?.ensureAudioGraph?.();
          }
        }
      }

      ensureEngineRunning();

      document.addEventListener("astro:page-load", reattachStudio);
      document.addEventListener("astro:after-swap", () => {
        requestAnimationFrame(reattachStudio);
        setTimeout(reattachStudio, 80);
        setTimeout(reattachStudio, 220);
      });

      window.addEventListener("abf:nowplaying-updated", reattachStudio);
      window.addEventListener("pageshow", reattachStudio);
      window.addEventListener("focus", reattachStudio);
      window.addEventListener("resize", reattachStudio);
      window.addEventListener("abf:audio-tools-ready", reattachStudio);
      document.addEventListener("visibilitychange", () => {
        if (document.visibilityState === "visible") reattachStudio();
      });
    })();
  </script>
</Base>