    }

    const run = () => {
      state.search.date = dateEl.value || "";
      state.search.time = timeEl.value || "";
      const payload = findClosestByDateTime(state.lastHistory, state.search.date, state.search.time, 10);
      renderAirSearchResult(root, payload);
