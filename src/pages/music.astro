  function stopTimer(){
    if (state.timer) clearInterval(state.timer);
    state.timer = null;
  }

  function startTimer(){
    stopTimer();
    state.timer = setInterval(() => {
      if (state.inFlight) return;
      render();
    }, 8000);
  }

