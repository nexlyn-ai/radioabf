    });
    window.addEventListener("abf:history-updated", () => {
      if (!isMusicRoute()) return;
      render();
    });
    window.addEventListener("resize", () => {
      if (!isMusicRoute()) return;
      const t = nowTs();
      if (t - state.lastRenderAt > 400) render();
    });
  }

  init();
})();
