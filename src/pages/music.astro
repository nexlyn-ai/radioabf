        if (k && exact[k] != null) return exact[k];
        if (k && lower[k.toLowerCase()] != null) return lower[k.toLowerCase()];

        const sp = k
          ? splitTrack(k)
          : { artist: String(artistMaybe || ""), title: String(titleMaybe || "") };

